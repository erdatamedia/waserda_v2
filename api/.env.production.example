# API runtime port (3000 and 8000 are already used on your VPS)
PORT=3100

# PostgreSQL connection
DATABASE_URL=postgresql://DB_USER:DB_PASS@127.0.0.1:5432/waserda?schema=public

# JWT secret (must be strong and private)
JWT_SECRET=CHANGE_ME_TO_STRONG_RANDOM_SECRET

# Allowed web origins, comma-separated
# Example with production + optional local admin dev
CORS_ORIGINS=https://admin.yourdomain.com,http://127.0.0.1:3101
